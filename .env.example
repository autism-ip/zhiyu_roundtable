# 知遇圆桌 - 环境变量配置示例
# 复制此文件为 .env.local 并填入实际值

# ============================================
# 应用配置
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=知遇圆桌

# ============================================
# 数据库配置 (PostgreSQL)
# ============================================
# 本地开发
DATABASE_URL=postgresql://username:password@localhost:5432/zhiyu_roundtable

# Supabase (生产环境)
# DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ============================================
# NextAuth 配置
# ============================================
NEXTAUTH_URL=http://localhost:3000
# 生成随机字符串: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-key-here

# ============================================
# SecondMe OAuth 配置
# 从 https://develop.second.me 获取
# ============================================
SECONDME_CLIENT_ID=your-secondme-client-id
SECONDME_CLIENT_SECRET=your-secondme-client-secret

# ============================================
# SecondMe API 配置
# ============================================
SECONDME_API_URL=https://api.mindverse.com/gate/lab
SECONDME_API_KEY=your-secondme-api-key

# ============================================
# OpenAI API 配置 (用于 Agent 编排)
# ============================================
OPENAI_API_KEY=sk-your-openai-api-key
# 可选: 指定组织ID
# OPENAI_ORG_ID=org-your-org-id

# ============================================
# Minimax API 配置 (用于 AI 分析)
# 从 https://www.minimaxi.com/platform 获取
# ============================================
MINIMAX_API_KEY=your-minimax-api-key

# ============================================
# 知乎 API 配置 (可选)
# 从 https://open.zhihu.com 获取
# ============================================
ZHIHU_APP_KEY=your-zhihu-app-key
ZHIHU_APP_SECRET=your-zhihu-app-secret

# ============================================
# 可选: 第三方服务配置
# ============================================

# Upstash Redis (用于缓存和会话)
# UPSTASH_REDIS_REST_URL=https://your-url.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token

# PostHog (用于分析)
# NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Sentry (用于错误追踪)
# SENTRY_DSN=your-sentry-dsn
# SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ============================================
# 开发调试配置
# ============================================
# 启用详细日志
# DEBUG=true

# 模拟API响应(用于离线开发)
# MOCK_API=true

# 跳过认证(仅用于测试)
# SKIP_AUTH=true
